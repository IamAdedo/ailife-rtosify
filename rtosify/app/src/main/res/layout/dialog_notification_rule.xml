<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">



    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rule_mode"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:textColor="?android:attr/textColorPrimary"/>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroupMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@+id/btnWhitelist">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWhitelist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/rule_whitelist"
            app:icon="@android:drawable/checkbox_on_background"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBlacklist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/rule_blacklist"
            app:icon="@android:drawable/ic_delete"
            style="@style/Widget.Material3.Button.OutlinedButton"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rule_patterns_title"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:textColor="?android:attr/textColorPrimary"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rule_patterns_desc"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        android:textColor="?android:attr/textColorSecondary"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/rule_title_pattern_hint"
        android:layout_marginTop="8dp"
        app:boxBackgroundMode="outline"
        app:helperText="Text to match in notification title">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTitlePattern"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/rule_content_pattern_hint"
        android:layout_marginTop="8dp"
        app:boxBackgroundMode="outline"
        app:helperText="Text to match in notification content">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editContentPattern"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="2"/>
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
