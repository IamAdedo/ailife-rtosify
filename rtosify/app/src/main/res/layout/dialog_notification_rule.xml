<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">



    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rule_mode"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:textColor="?android:attr/textColorPrimary"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:padding="4dp">

        <Button
            android:id="@+id/btnWhitelist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/rule_whitelist"
            android:textColor="@android:color/holo_green_dark"
            android:layout_marginEnd="4dp"
            android:minHeight="48dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btnBlacklist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/rule_blacklist"
            android:textColor="@android:color/holo_red_dark"
            android:layout_marginStart="4dp"
            android:minHeight="48dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rule_patterns_title"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:textColor="?android:attr/textColorPrimary"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rule_patterns_desc"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        android:textColor="?android:attr/textColorSecondary"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/rule_title_pattern_hint"
        android:layout_marginTop="8dp"
        app:boxBackgroundMode="outline"
        app:helperText="Text to match in notification title">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTitlePattern"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/rule_content_pattern_hint"
        android:layout_marginTop="8dp"
        app:boxBackgroundMode="outline"
        app:helperText="Text to match in notification content">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editContentPattern"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="2"/>
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
