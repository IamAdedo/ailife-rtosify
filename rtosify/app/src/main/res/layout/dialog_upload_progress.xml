<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvUploadTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Transfer Status"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <ImageView
        android:id="@+id/imgUploadIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:src="@android:drawable/ic_menu_upload"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvUploadDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Transferring file..."
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <ProgressBar
        android:id="@+id/progressBarUpload"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tvUploadPercentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnViewFile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View File"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnUploadOk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OK"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
