<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#212121"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header: Name and Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imgDeviceIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_smartwatch"
            android:contentDescription="Device" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvWidgetDeviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Watch"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWidgetStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disconnected"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imgWidgetBattery"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_battery_full"
            android:contentDescription="Battery" />

        <TextView
            android:id="@+id/tvWidgetBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="--%"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#44FFFFFF" />

    <!-- Info Row: WiFi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/imgWidgetWifi"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_wifi"
            android:contentDescription="WiFi" />

        <TextView
            android:id="@+id/tvWidgetWifiTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="WiFi:"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvWidgetWifiSsid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="Not Connected"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Actions Row -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#44FFFFFF" />

    <!-- Action Buttons (auto-hide when widget is too short) -->
    <LinearLayout
        android:id="@+id/layoutWidgetActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:minHeight="60dp">

        <!-- DND Toggle -->
        <LinearLayout
            android:id="@+id/layoutWidgetDnd"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="#00000000">

            <ImageView
                android:id="@+id/imgWidgetDnd"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_do_not_disturb"
                android:contentDescription="DND" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dnd_normal"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Mirror Toggle -->
        <LinearLayout
            android:id="@+id/layoutWidgetMirror"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="#00000000">

            <ImageView
                android:id="@+id/imgWidgetMirror"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_cast"
                android:contentDescription="Mirror" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mirror"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
