<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvShareTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/automation_sharing_sync_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <ImageView
        android:id="@+id/imgShareIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_share"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvShareStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sharing_sync_preparing"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressBarShare"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100" />

    <TextView
        android:id="@+id/tvSharePercentage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0%"
        android:layout_marginTop="8dp" />

</LinearLayout>
