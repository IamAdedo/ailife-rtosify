<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#212121"
    android:orientation="vertical"
    android:padding="12dp"
    android:gravity="center">

    <!-- Connection Status Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/img_connection_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_bluetooth"
            android:layout_marginEnd="10dp"
            android:contentDescription="Connection"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/device_phone"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txt_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_disconnected"
                android:textColor="#AAAAAA"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#44FFFFFF"
        android:layout_marginBottom="8dp"/>

    <!-- Battery Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:layout_marginBottom="8dp">

        <!-- Phone Battery -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_smartphone"
                android:contentDescription="Phone"/>

            <TextView
                android:id="@+id/txt_phone_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/battery_percent_placeholder"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/device_phone"
                android:textColor="#888888"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- Watch Battery -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_watch"
                android:contentDescription="Watch"/>

            <TextView
                android:id="@+id/txt_watch_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/battery_percent_placeholder"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/device_watch"
                android:textColor="#888888"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- Transport Type -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/img_transport_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_bluetooth"
                android:contentDescription="@string/label_transport"/>

            <TextView
                android:id="@+id/txt_transport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_transport_bt"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_link"
                android:textColor="#888888"
                android:textSize="9sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#44FFFFFF"
        android:layout_marginBottom="8dp"/>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Mirror Button -->
        <LinearLayout
            android:id="@+id/btn_mirror"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/imgBtnMirror"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_cast"
                android:contentDescription="Mirror"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_mirror"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Camera Button -->
        <LinearLayout
            android:id="@+id/btn_camera"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/imgBtnCamera"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_camera"
                android:contentDescription="Camera"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_camera"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Dialer Button -->
        <LinearLayout
            android:id="@+id/btn_dialer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/imgBtnDialer"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_phone"
                android:contentDescription="Dialer"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_dialer"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>

