<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/widget_root">

    <!-- Album Art Background -->
    <ImageView
        android:id="@+id/img_album_art"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@android:color/darker_gray"
        android:contentDescription="@string/media_album_art" />

    <!-- Overlay Gradient/Background -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center">

        <!-- Title & Artist (Clickable to open activity) -->
        <LinearLayout
            android:id="@+id/layout_title_click"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/txt_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/media_no_media_short"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/txt_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_not_connected"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Playback Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_media_prev"
                android:background="#00000000"
                android:scaleType="centerInside"
                android:contentDescription="@string/media_prev_desc" />

            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_media_play"
                android:background="#009688"
                android:scaleType="centerInside"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:contentDescription="@string/media_play_pause_desc" />

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_media_next"
                android:background="#00000000"
                android:scaleType="centerInside"
                android:contentDescription="@string/media_next_desc" />
        </LinearLayout>

        <!-- Volume Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_vol_down"
                android:layout_width="56dp"
                android:layout_height="40dp"
                android:text="@string/label_minus"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:gravity="center"
                android:background="#444444"
                android:layout_marginEnd="24dp"/>
            
             <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/media_volume_label"
                android:textSize="12sp"
                android:textColor="#999999"/>

            <TextView
                android:id="@+id/btn_vol_up"
                android:layout_width="56dp"
                android:layout_height="40dp"
                android:text="@string/label_plus"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:gravity="center"
                android:background="#444444"
                android:layout_marginStart="24dp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
