<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="?android:attr/colorBackground">

        <ImageView
            android:id="@+id/imgStatus"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_smartwatch"
            app:tint="?attr/colorPrimary"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tvWelcomeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_configuring"
            android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:textAlignment="center"/>

        <TextView
            android:id="@+id/tvWelcomeStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_preparing"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:textAlignment="center"/>

        <ImageView
            android:id="@+id/imgQrCode"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_marginBottom="16dp"
            android:background="@android:color/white"
            android:padding="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnFinishedSetup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_btn_finished"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnAlreadyPaired"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_btn_already_paired"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <ProgressBar
            android:id="@+id/progressBarSetup"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:visibility="visible"/>

        <!-- Cards were removed to simplify the automatic process -->
        <View
            android:id="@+id/cardSmartphone"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
        <View
            android:id="@+id/cardWatch"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>