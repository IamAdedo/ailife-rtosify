<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@color/black">

    <TextView
        android:id="@+id/tv_stopwatch_elapsed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="00:00.00"
        android:textColor="#FFFFFF"
        android:textSize="44sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_stopwatch_start_stop"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/stopwatch_start"
            android:backgroundTint="#2ECC71"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btn_stopwatch_lap_reset"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/stopwatch_lap"
            android:backgroundTint="#444444"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

    <ListView
        android:id="@+id/lv_stopwatch_laps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:divider="#333333"
        android:dividerHeight="1dp"/>

</LinearLayout>
