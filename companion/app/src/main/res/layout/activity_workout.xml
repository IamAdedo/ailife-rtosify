<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@color/black">

    <!-- Workout type header -->
    <TextView
        android:id="@+id/tv_workout_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Running"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <!-- Elapsed time — prominent -->
    <TextView
        android:id="@+id/tv_workout_elapsed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#FFFFFF"
        android:textSize="48sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Heart rate + zone row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tv_workout_hr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="-- bpm"
            android:textColor="#FF4444"
            android:textSize="20sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_workout_zone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Zone --"
            android:textColor="#FF8C00"
            android:textSize="16sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Pace + distance row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tv_workout_pace"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="--:-- /km"
            android:textColor="#AAFFAA"
            android:textSize="16sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_workout_distance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0.00 km"
            android:textColor="#AAAAFF"
            android:textSize="16sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Calories + cadence row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_workout_calories"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 kcal"
            android:textColor="#FFCC44"
            android:textSize="14sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tv_workout_cadence"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="-- spm"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_workout_pause"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/workout_pause"
            android:backgroundTint="#444444"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn_workout_stop"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/workout_stop"
            android:backgroundTint="#CC0000"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>
