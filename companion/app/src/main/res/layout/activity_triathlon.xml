<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@color/black">

    <TextView
        android:id="@+id/tv_triathlon_sport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/triathlon_swim"
        android:textColor="#4488FF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tv_triathlon_elapsed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#FFFFFF"
        android:textSize="44sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_triathlon_hr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="-- bpm"
            android:textColor="#FF4444"
            android:textSize="16sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tv_triathlon_dist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0.00 km"
            android:textColor="#AAAAFF"
            android:textSize="16sp"
            android:gravity="center"/>

    </LinearLayout>

    <!-- Segment indicator dots -->
    <LinearLayout
        android:id="@+id/ll_triathlon_segments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_triathlon_next"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="6dp"
        android:text="@string/triathlon_next_segment"
        android:backgroundTint="#4488FF"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>

    <Button
        android:id="@+id/btn_triathlon_finish"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="@string/triathlon_finish"
        android:backgroundTint="#CC0000"
        android:textColor="#FFFFFF"/>

</LinearLayout>
