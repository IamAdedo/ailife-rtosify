<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================ -->
    <!-- PERMISSÕES -->
    <!-- ============================================================ -->

    <!-- Bluetooth (Legado - Android 11 e inferior) -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />

    <!-- CORREÇÃO: Localização Precisa necessária para ler SSID do Wi-Fi em TODAS as versões -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Opcional: Localização em Background para Android 10+ (melhora leitura de Wi-Fi com tela desligada) -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Bluetooth (Moderno - Android 12+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" android:usesPermissionFlags="neverForLocation" tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />

    <!-- WiFi (Android 13+) -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" android:usesPermissionFlags="neverForLocation" tools:targetApi="tiramisu" />

    <!-- Serviços e Sistema -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" /> <!-- Necessário para ler Wi-Fi no serviço -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" tools:targetApi="34" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" tools:targetApi="34" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" tools:ignore="ExactAlarm" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- APK Installation/Uninstallation (Watch needs this for phone-triggered app management) -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" tools:ignore="QueryAllPackagesPermission" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.BATTERY_STATS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.DUMP" tools:ignore="ProtectedPermissions" />

    <!-- NOVAS PERMISSÕES PARA STATUS -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WRITE_SETTINGS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" tools:ignore="ScopedStorage" />

    <!-- Better Health Tracker API -->
    <uses-permission android:name="com.ailife.betterhealth.READ_HEALTH_DATA" />
    <uses-permission android:name="com.ailife.betterhealth.WRITE_HEALTH_DATA" />

    <!-- Calendar and Contacts Sync -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <queries>
        <package android:name="moe.shizuku.privileged.api" />
    </queries>


    <application
        android:name=".CompanionApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Smartwatch"
        android:usesCleartextTraffic="true"
        android:requestLegacyExternalStorage="true">

        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:enabled="true"
            android:exported="true"
            android:multiprocess="false" />

        <!-- Activity Principal -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ShareToPhoneActivity"
            android:exported="true"
            android:label="Share to Phone"
            android:theme="@style/Theme.Smartwatch">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>

        <activity
            android:name=".WelcomeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".PermissionActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Smartwatch" />

        <!-- Serviço Bluetooth -->
        <!-- Adicionado "location" para permitir leitura de Wi-Fi em background -->
        <service
            android:name=".BluetoothService"
            android:enabled="true"
            android:exported="true"
            android:foregroundServiceType="connectedDevice|location" />

        <!-- Accessibility Service for Bluetooth Tethering Automation -->
        <service
            android:name=".RtosifyAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true"
            android:process=":accessibility">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Boot Receiver -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- Notification Action Receiver -->
        <receiver
            android:name=".NotificationActionReceiver"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".DndReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.iamadedo.watchapp.ACTION_DND_ON" />
                <action android:name="com.iamadedo.watchapp.ACTION_DND_OFF" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".AlarmReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.iamadedo.watchapp.ALARM_TRIGGER" />
                <action android:name="com.iamadedo.watchapp.DISMISS_ALARM" />
                <action android:name="com.iamadedo.watchapp.SNOOZE_ALARM" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".KeepaliveReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.iamadedo.watchapp.ACTION_KEEPALIVE_TRIGGER" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <activity
            android:name=".FindDeviceActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".FindDeviceAlarmActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".FilePreviewActivity"
            android:enabled="true"
            android:exported="false"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".FullScreenNotificationActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".FullScreenMediaActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".VideoHelperActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".MediaControlActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".CameraRemoteActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".DialerActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".PhoneSettingsActivity"
            android:exported="true"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".CallActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".AlarmRingingActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".AlarmManagementActivity"
            android:exported="true"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".MirrorActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".MirrorSettingsActivity"
            android:exported="true"
            android:label="@string/title_activity_mirror_settings"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".NavigationOverlayActivity"
            android:exported="false"
            android:theme="@style/Theme.Smartwatch"
            android:launchMode="singleTop"/>

        <activity
            android:name=".NotificationLogActivity"
            android:exported="true"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Smartwatch" />

        <activity
            android:name=".ReplyDialogActivity"
            android:exported="false"
            android:theme="@style/Theme.Smartwatch.Translucent" />

        <activity
            android:name=".RingtonePickerActivity"
            android:exported="false"
            android:theme="@style/Theme.Smartwatch.Translucent" />

        <service
            android:name=".MirroringService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaProjection"
            tools:targetApi="q" />

        <!-- Dynamic Island Service -->
        <service
            android:name=".DynamicIslandService"
            android:enabled="true"
            android:exported="true"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Overlay for status updates and notifications on companion device" />
        </service>

        <!-- Media Widget -->
         <receiver
            android:name=".widget.MediaWidget"
            android:label="@string/widget_media_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.iamadedo.watchapp.widget.ACTION_MEDIA_UPDATE" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_media_info" />
        </receiver>

        <!-- Dashboard Widget -->
        <receiver
            android:name=".widget.DashboardWidget"
            android:label="@string/widget_dashboard_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.iamadedo.watchapp.widget.ACTION_DASHBOARD_UPDATE" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_dashboard_info" />
        </receiver>

        <!-- Notification Log Widget -->
        <receiver
            android:name=".widget.NotificationLogWidget"
            android:label="@string/title_notification_history"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.iamadedo.watchapp.widget.ACTION_NOTIFICATION_LOG_UPDATE" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_notification_log_info" />
        </receiver>

        <service
            android:name=".widget.NotificationLogRemoteViewsService"
            android:permission="android.permission.BIND_REMOTEVIEWS" />



        <!-- FileProvider (for APK installation) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- NEW FEATURES                                                       -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <!-- Emergency SOS countdown screen -->
        <activity
            android:name=".SosActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:keepScreenOn="true"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <!-- Workout tracking screen -->
        <activity
            android:name=".WorkoutActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <!-- Guided breathing / mindfulness screen -->
        <activity
            android:name=".MindfulnessActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <!-- Fall detection foreground service -->
        <service
            android:name=".FallDetectionService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- Torch / flashlight screen -->
        <activity
            android:name=".TorchActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen"
            android:screenOrientation="portrait"/>

        <!-- Standalone stopwatch -->
        <activity
            android:name=".StopwatchActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:screenOrientation="portrait"/>

        <!-- Triathlon multi-sport tracker -->
        <activity
            android:name=".TriathlonActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:screenOrientation="portrait"/>

        <!-- Bedtime mode scheduled alarm receiver -->
        <receiver
            android:name=".BedtimeModeReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.iamadedo.watchapp.BEDTIME_START"/>
                <action android:name="com.iamadedo.watchapp.BEDTIME_END"/>
            </intent-filter>
        </receiver>

    </application>
</manifest>